{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python -u run_live_futures.py --strategy ${BOT_STRATEGY:-supertrend} --interval ${BOT_INTERVAL:-4h} --symbol ${BOT_SYMBOL:-BTCUSDT} --poll ${BOT_POLL:-30} --budget ${BOT_BUDGET:-500} --leverage ${BOT_LEV:-3}",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1
  }
}
