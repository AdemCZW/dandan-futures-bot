# ═══════════════════════════════════════════════════════════════════
# 丹丹交易團隊 — 本機開發環境變數範本
# 全程虛擬資金、只連測試網、不碰真錢。複製成 .env 後填值（.env 已在 .gitignore）。
# 正式部署（Railway）的環境變數在 Railway 面板 Variables 設定，不走這個檔案。
# ═══════════════════════════════════════════════════════════════════

# ── 合約測試網金鑰（本機跑 run_live_futures.py / run_multi_futures.py 才需要）──
# 從 https://testnet.binancefuture.com 登入產生（HMAC）。虛擬資金、不碰真錢。
# 純回測 / paper 模式不需要金鑰。
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key_here
BINANCE_FUTURES_TESTNET_API_SECRET=your_futures_testnet_api_secret_here

# ── 前端讀取 Railway 上 9 台 bot 即時狀態 ──
# 部署後從 Railway 面板複製 dandan-futures-bot 的公開 URL。
# 留空則只讀本機狀態檔（本機 paper / 合約 bot）。
# 註：舊的 RAILWAY_BOT_URL_2/3/4 已移除——分離 bot 服務已關閉、合併成單一 9 台容器。
RAILWAY_BOT_URL=https://dandan-futures-bot-production.up.railway.app

# ── 手動平倉共用密鑰（選填）──
# 設了才啟用儀表板「手動平倉」代理；需與 bot 端 CLOSE_TOKEN 一致。空=停用平倉代理。
CLOSE_TOKEN=

# ── 現貨測試網金鑰（選填，僅舊的 run_live.py 現貨模式用，現行 9 台 bot 不需要）──
# 從 https://testnet.binance.vision/ 產生，與上面的【合約】測試網金鑰完全獨立。
# BINANCE_TESTNET_API_KEY=your_spot_testnet_api_key_here
# BINANCE_TESTNET_API_SECRET=your_spot_testnet_api_secret_here
