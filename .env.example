# 從 https://testnet.binance.vision/ 登入後產生「測試網」金鑰，貼到這裡
# 注意：這是【現貨測試網】金鑰，不是你正式幣安帳號的金鑰。兩者完全獨立。
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# 合約測試網金鑰（run_live_futures.py 才需要，支援做空）。
# 從 https://testnet.binancefuture.com 登入產生，與上面的【現貨】測試網金鑰完全獨立。
# 一樣是虛擬資金、不碰真錢。
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key_here
BINANCE_FUTURES_TESTNET_API_SECRET=your_futures_testnet_api_secret_here

# Railway 雲端 bot 狀態 URL（本機前端讀取 Railway 上的 bot 即時狀態用）。
# 部署後從 Railway 面板 → Settings → Networking 複製公開 URL，貼到這裡。
# 留空則只讀本機狀態檔（paper bot / 本機合約 bot）。
RAILWAY_BOT_URL=

# 第二台 bot 的 Railway URL，供前端 /api/live2 顯示（例：rsi2_connors BTCUSDT 4h）
RAILWAY_BOT_URL_2=

# 第三台 bot 的 Railway URL，供前端 /api/live3 顯示（例：fib_retracement SOLUSDT 1h）
RAILWAY_BOT_URL_3=
